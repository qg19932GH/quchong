{
  "name": "quchong-tool",
  "version": "1.0.0",
  "description": "Video duplicate finder based on video ID / AV codes / FC2",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.quchong.tool",
    "productName": "视频去重工具",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "portable"
      ]
    },
    "portable": {
      "artifactName": "${productName}_便携版_${version}.${ext}"
    }
  }
}
